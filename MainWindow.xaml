<Window x:Class="uyutov_lab25.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="800">
    <Grid Name="MainGrid" Margin="10">
        <StackPanel>
            <!-- TextBox привязанный к строковому свойству -->
            <TextBox x:Name="TextBoxString" Margin="5" />

            <!-- CheckBox привязанный к логическому свойству -->
            <CheckBox x:Name="CheckBoxBool" Content="Включено" Margin="5" />

            <!-- TextBox для целого числа -->
            <TextBox x:Name="TextBoxInt" Margin="5" />

            <!-- TextBox для вещественного числа -->
            <TextBox x:Name="TextBoxDouble" Margin="5" />

            <!-- Rectangle для демонстрации цвета -->
            <Rectangle x:Name="ColorRectangle" Width="100" Height="50" Margin="5" />

            <!-- кнопка для привязки -->
            <Button Content="Создать динамическую привязку" Margin="5" Click="CreateDynamicBinding"/>
        </StackPanel>
    </Grid>
</Window>